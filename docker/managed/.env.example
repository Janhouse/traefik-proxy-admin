# Fully-managed Traefik bundle — copy to the repo root as .env:
#   cp docker/managed/.env.example .env

# ── Database ────────────────────────────────────────────────────────────────
POSTGRES_DB=traefik_share
POSTGRES_USER=admin
# Required. Generate one: openssl rand -hex 24
POSTGRES_PASSWORD=

# ── Images (optional overrides) ─────────────────────────────────────────────
#CONFIGURATOR_IMAGE=ghcr.io/janhouse/traefik-proxy-admin:latest
#TRAEFIK_IMAGE=traefik:v3.7

# ── Admin panel HTTP auth (htpasswd entries, comma- or newline-separated) ──
# The panel is only reachable through Traefik; this basicAuth protects it.
# Generate an entry:
#   htpasswd -nB admin           (apache2-utils)
#   docker run --rm httpd:alpine htpasswd -nB admin
# IMPORTANT: wrap the value in single quotes so docker compose does not try
# to interpolate the $ characters inside the hash (or escape each $ as $$).
# Example:
#   ADMIN_PANEL_AUTH='admin:$2y$05$xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx'
ADMIN_PANEL_AUTH=

# ── DNS challenge credentials (only if you use a dnsChallenge resolver) ────
# Preferred: set these in the admin panel under
#   Config → Managed Traefik → DNS provider credentials.
# They are stored write-only (never readable back through the web) and the
# Traefik wrapper injects them as env vars on each (re)start.
# Alternatively, hard-code them on the traefik service in
# docker-compose.managed.yml, e.g. for Cloudflare:
#CF_DNS_API_TOKEN=
