# Database Configuration
DATABASE_URL=postgresql://admin:password@localhost:5432/traefik_share

# SSO Configuration (configured via admin panel)
# These are examples of what would be stored in the app_config table
# SSO_IDP_URL=https://your-idp.com
# SSO_CLIENT_ID=your-client-id
# SSO_CLIENT_SECRET=your-client-secret
# SSO_REDIRECT_URI=http://localhost:3000/api/auth/sso/callback

# Application Configuration
NODE_ENV=development
NEXT_PUBLIC_BASE_URL=http://localhost:3000

# Traefik API integration — enables entrypoint discovery in the route editor,
# the runtime explorer, route-conflict detection and traffic metrics.
# Point this at Traefik's API (enable it with --api.insecure=true, or route it
# through an authenticated entrypoint). In dev, docker-compose.test.yml
# exposes it on :8080.
TRAEFIK_API_URL=http://localhost:8080
# Optional metrics tuning (defaults shown); metrics scrape uses
# TRAEFIK_METRICS_URL or falls back to TRAEFIK_API_URL/metrics.
# TRAEFIK_METRICS_URL=http://localhost:8080/metrics
# TRAEFIK_METRICS_INTERVAL_SECONDS=60
# TRAEFIK_METRICS_RETENTION_MINUTES=180